{
  "Launcher": {
    "ServiceName": "Epsilon.Launcher",
    "GatewayBaseUrl": "http://127.0.0.1:5100",
    "GatewayRealtimePath": "/realtime",
    "AssetsBaseUrl": "/assets",
    "DesktopLauncher": {
      "HotelBaseUrl": "http://localhost:4100",
      "LauncherApiBaseUrl": "http://localhost:5001",
      "DefaultChannel": "stable",
      "DefaultProfileKey": "loader-desktop",
      "LocalConfigDefaults": {
        "AutoLaunchOnRedeem": true,
        "CloseCmsOnLaunch": false,
        "HardwareAcceleration": true,
        "TelemetryEnabled": true,
        "RememberLastProfile": true
      },
      "UpdateChannels": [
        {
          "ChannelKey": "stable",
          "DisplayName": "Stable",
          "LauncherManifestUrl": "https://launcher.example.com/stable/launcher.json",
          "PackageManifestUrl": "https://launcher.example.com/stable/packages.json",
          "AllowDowngrade": false,
          "RequiresSignedPackages": true
        },
        {
          "ChannelKey": "beta",
          "DisplayName": "Beta",
          "LauncherManifestUrl": "https://launcher.example.com/beta/launcher.json",
          "PackageManifestUrl": "https://launcher.example.com/beta/packages.json",
          "AllowDowngrade": false,
          "RequiresSignedPackages": true
        },
        {
          "ChannelKey": "internal",
          "DisplayName": "Internal",
          "LauncherManifestUrl": "https://launcher.example.com/internal/launcher.json",
          "PackageManifestUrl": "https://launcher.example.com/internal/packages.json",
          "AllowDowngrade": true,
          "RequiresSignedPackages": false
        }
      ],
      "LaunchProfiles": [
        {
          "ProfileKey": "loader-desktop",
          "DisplayName": "Loader del juego",
          "Channel": "stable",
          "Platforms": [ "Windows", "macOS", "Linux", "iPhone", "Android" ],
          "ClientKind": "loader",
          "PackageKey": "game_loader_desktop",
          "EntryExecutable": "Loader",
          "Arguments": [ "{entryAssetUrl}" ],
          "RequiresRedeemCode": false,
          "SupportsSafeReconnect": true,
          "SupportsOverlayTelemetry": false,
          "IsDefault": true
        },
        {
          "ProfileKey": "unity-desktop",
          "DisplayName": "Unity Desktop",
          "Channel": "beta",
          "Platforms": [ "Windows", "macOS", "Linux" ],
          "ClientKind": "unity",
          "PackageKey": "unity_desktop_main",
          "EntryExecutable": "EpsilonHotel",
          "Arguments": [ "--redeem-ticket={ticket}" ],
          "RequiresRedeemCode": true,
          "SupportsSafeReconnect": true,
          "SupportsOverlayTelemetry": true,
          "IsDefault": false
        },
        {
          "ProfileKey": "nitro-desktop",
          "DisplayName": "Nitro Desktop",
          "Channel": "beta",
          "Platforms": [ "Windows", "macOS", "Linux" ],
          "ClientKind": "nitro",
          "PackageKey": "nitro_desktop_main",
          "EntryExecutable": "NitroClient",
          "Arguments": [ "--redeem-ticket={ticket}" ],
          "RequiresRedeemCode": true,
          "SupportsSafeReconnect": true,
          "SupportsOverlayTelemetry": true,
          "IsDefault": false
        }
      ]
    },
    "ClientProfiles": [
      {
        "ProfileKey": "release63",
        "DisplayName": "Release 63 Compatibility",
        "PackageKey": "flash_release63_baseline",
        "RendererKind": "compatibility_web",
        "TransportKind": "epsilon_realtime_wss",
        "SupportsSso": true,
        "SupportsDirectLogin": true,
        "IsDefault": false,
        "SupportedDevices": [ "Desktop", "Tablet" ],
        "Tags": [ "compatibility", "release63", "classic" ]
      },
      {
        "ProfileKey": "game-loader",
        "DisplayName": "Loader del juego",
        "PackageKey": "game_loader_desktop",
        "RendererKind": "epsilon_loader",
        "TransportKind": "epsilon_realtime_wss",
        "SupportsSso": true,
        "SupportsDirectLogin": true,
        "IsDefault": true,
        "SupportedDevices": [ "Desktop", "Tablet", "Phone" ],
        "Tags": [ "modern", "web", "adaptive" ]
      }
    ],
    "ConnectionProfiles": [
      {
        "DeviceKind": "Desktop",
        "TransportKind": "epsilon_realtime_wss",
        "ProtocolFamily": "epsilon-desktop",
        "InputMode": "pointer_keyboard",
        "SupportsTouchInput": false,
        "SupportsSafeReconnect": true,
        "RequiresCompactViewport": false,
        "HeartbeatIntervalSeconds": 20,
        "MaximumViewportWidth": 1600,
        "MaximumViewportHeight": 1200,
        "PreferredAssetDensity": 1.0,
        "EnabledCapabilities": [ "session-resume", "full-room-ui", "pointer-navigation", "keyboard-shortcuts" ]
      },
      {
        "DeviceKind": "Tablet",
        "TransportKind": "epsilon_realtime_wss",
        "ProtocolFamily": "epsilon-touch",
        "InputMode": "touch",
        "SupportsTouchInput": true,
        "SupportsSafeReconnect": true,
        "RequiresCompactViewport": true,
        "HeartbeatIntervalSeconds": 18,
        "MaximumViewportWidth": 1180,
        "MaximumViewportHeight": 1024,
        "PreferredAssetDensity": 1.5,
        "EnabledCapabilities": [ "session-resume", "touch-navigation", "gesture-room-controls", "compact-ui" ]
      },
      {
        "DeviceKind": "Phone",
        "TransportKind": "epsilon_realtime_wss",
        "ProtocolFamily": "epsilon-touch",
        "InputMode": "touch",
        "SupportsTouchInput": true,
        "SupportsSafeReconnect": true,
        "RequiresCompactViewport": true,
        "HeartbeatIntervalSeconds": 15,
        "MaximumViewportWidth": 540,
        "MaximumViewportHeight": 960,
        "PreferredAssetDensity": 2.0,
        "EnabledCapabilities": [ "session-resume", "touch-navigation", "gesture-room-controls", "minimal-ui" ]
      }
    ]
  }
}
