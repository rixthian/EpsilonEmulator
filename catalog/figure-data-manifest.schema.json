{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epsilon.local/catalog/figure-data-manifest.schema.json",
  "title": "Figure Data Manifest",
  "type": "object",
  "required": [
    "manifestVersion",
    "generatedAtUtc",
    "manifestKey",
    "eraKey",
    "sourcePath",
    "setTypeCount",
    "paletteCount",
    "genderSetCounts",
    "partTypeCounts",
    "paletteColorCounts",
    "avatarBundleContext",
    "setTypes",
    "palettes"
  ],
  "properties": {
    "manifestVersion": { "type": "integer", "const": 1 },
    "generatedAtUtc": { "type": "string" },
    "manifestKey": { "type": "string", "minLength": 1 },
    "eraKey": { "type": "string", "minLength": 1 },
    "sourcePath": { "type": "string", "minLength": 1 },
    "setTypeCount": { "type": "integer", "minimum": 0 },
    "paletteCount": { "type": "integer", "minimum": 0 },
    "genderSetCounts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "partTypeCounts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "paletteColorCounts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "avatarBundleContext": {
      "type": ["object", "null"]
    },
    "setTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "paletteId", "mandatory", "setCount", "partCount", "sets"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "paletteId": { "type": "integer", "minimum": 0 },
          "mandatory": { "type": "object" },
          "setCount": { "type": "integer", "minimum": 0 },
          "partCount": { "type": "integer", "minimum": 0 },
          "sets": { "type": "array" }
        }
      }
    },
    "palettes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "colorCount", "colors"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "colorCount": { "type": "integer", "minimum": 0 },
          "colors": { "type": "array" }
        }
      }
    }
  }
}
