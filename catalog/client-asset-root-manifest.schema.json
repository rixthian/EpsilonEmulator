{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epsilon.local/schemas/client-asset-root-manifest.schema.json",
  "title": "Client Asset Root Manifest",
  "type": "object",
  "required": ["manifestVersion", "generatedAtUtc", "rootId", "layoutKind", "sections"],
  "properties": {
    "manifestVersion": { "type": "integer" },
    "generatedAtUtc": { "type": "string" },
    "rootId": { "type": "string" },
    "layoutKind": { "type": "string" },
    "sections": {
      "type": "object",
      "required": [
        "gamedata",
        "imageLibrary",
        "dcrFurnitureAssets",
        "gordonPackages",
        "coreClientPackages",
        "publicRoomPackages",
        "avatarAssets",
        "petAssets"
      ],
      "properties": {
        "gamedata": { "type": "object" },
        "imageLibrary": { "type": "object" },
        "dcrFurnitureAssets": { "type": "object" },
        "gordonPackages": { "type": "object" },
        "coreClientPackages": { "type": "object" },
        "publicRoomPackages": { "type": "object" },
        "avatarAssets": { "type": "object" },
        "petAssets": { "type": "object" }
      }
    }
  }
}
