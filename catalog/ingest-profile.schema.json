{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epsilon.local/schemas/ingest-profile.schema.json",
  "title": "Ingest Profile",
  "type": "object",
  "required": [
    "manifestVersion",
    "profileKey",
    "sourceKind",
    "clientFamily",
    "eraKey",
    "roots"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "minimum": 1
    },
    "profileKey": {
      "type": "string",
      "minLength": 1
    },
    "sourceKind": {
      "type": "string",
      "enum": ["local", "remote", "mixed"]
    },
    "clientFamily": {
      "type": "string",
      "minLength": 1
    },
    "eraKey": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": ["string", "null"]
    },
    "revisionKey": {
      "type": ["string", "null"]
    },
    "roots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rootKey", "path"],
        "properties": {
          "rootKey": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
